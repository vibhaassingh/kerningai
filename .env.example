# =============================================================================
# Kerning AI — environment variables
# =============================================================================
# Copy to `.env.local` for local development. For Vercel preview + production,
# add via `vercel env add <KEY> <env>`.
#
# `NEXT_PUBLIC_*` is exposed to the browser — never put a secret there.
# Service-role keys + provider secrets stay server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENV=local
ALLOWED_REDIRECT_HOSTS=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Local: `pnpm db:start` prints these. Staging/Prod: from the Supabase
# project dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Client. Authorized redirect URI must match
# `<NEXT_PUBLIC_SITE_URL>/auth/callback` AND the Supabase project's
# `<supabase-url>/auth/v1/callback`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend — already wired for the marketing contact form)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_TO_EMAIL=

# -----------------------------------------------------------------------------
# Cron — Vercel sets this automatically on cron-triggered invocations.
# Paste the same value into your local .env.local if you want to test
# `/api/cron/*` endpoints from your machine.
# -----------------------------------------------------------------------------
CRON_SECRET=

# -----------------------------------------------------------------------------
# Rate limiting — Upstash Redis (Phase 5b; safe to leave blank in 4–5)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Observability — Sentry (Phase 5b; stub falls back to console)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# SEO verification (already used in app/layout.tsx)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GSC_TOKEN=
NEXT_PUBLIC_BING_TOKEN=
