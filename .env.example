# =============================================================================
# Kerning AI — environment variables
# =============================================================================
# Copy this file to `.env.local` for local development. For Vercel preview
# + production, add the same keys via `vercel env add <KEY> <env>` so they
# stay encrypted at rest.
#
# `NEXT_PUBLIC_*` values are exposed to the browser — never put a secret
# there. Service-role keys and provider secrets stay server-only.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
APP_ENV=local
# Comma-separated extra hosts the auth flow can redirect back to. The site
# URL host is always allowed automatically.
ALLOWED_REDIRECT_HOSTS=

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Local: `supabase start` prints these. Staging/Prod: from the Supabase
# project dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional — required only if you sign custom JWT claims.
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth
# -----------------------------------------------------------------------------
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0
# Client. Authorized redirect URI must match
# `<NEXT_PUBLIC_SITE_URL>/auth/callback` AND the Supabase project's
# `<supabase-url>/auth/v1/callback`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend — already wired for the marketing contact form)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# Defaults to `Kerning AI <onboarding@resend.dev>`. Switch to
# `Kerning AI <hello@kerningai.eu>` once DNS is verified on Resend.
RESEND_FROM_EMAIL=
# Comma-separated recipient inboxes for the contact form.
CONTACT_TO_EMAIL=

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
# Set by Vercel automatically when you add a cron job. Override locally
# if you want to hit cron endpoints from your machine.
CRON_SECRET=

# -----------------------------------------------------------------------------
# Rate limiting — Upstash Redis (Phase 2; safe to leave blank in Phase 1)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# SEO verification (already used in app/layout.tsx)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GSC_TOKEN=
NEXT_PUBLIC_BING_TOKEN=
